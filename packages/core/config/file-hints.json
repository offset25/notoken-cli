    ],
    "logs": [
      { "path": "/var/log/postgresql/", "description": "Log directory" }
    ],
    "data": [
      { "path": "/var/lib/postgresql/", "description": "Data directory" }
    ],
    "service": "postgresql",
    "parser": "text"
  },
  "mysql": {
    "aliases": ["mysql", "mariadb", "maria"],
